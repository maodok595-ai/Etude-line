# ========================================
# CONFIGURATION POUR DÉPLOIEMENT RENDER
# ========================================
# Copier ce fichier en .env et remplir les valeurs
# Sur Render : Configurer ces variables dans "Environment Variables"

# ========================================
# BASE DE DONNÉES POSTGRESQL
# ========================================
# URL de connexion PostgreSQL (fournie automatiquement par Render si vous utilisez PostgreSQL Render)
DATABASE_URL=postgresql://user:password@host:5432/database_name

# Variables individuelles (optionnelles si DATABASE_URL est défini)
PGHOST=your-postgres-host.render.com
PGPORT=5432
PGDATABASE=etude_line_db
PGUSER=etude_line_user
PGPASSWORD=your_secure_password

# ========================================
# AUTHENTIFICATION ADMINISTRATEUR
# ========================================
# Identifiants pour le compte administrateur principal
# ⚠️ IMPORTANT : Changez ces valeurs par défaut !
ADMIN_USERNAME=kamaodo65
ADMIN_PASSWORD=admin123

# ========================================
# SÉCURITÉ SESSION
# ========================================
# Clé secrète pour signer les sessions utilisateurs
# Générez une clé aléatoire forte (minimum 32 caractères)
# Exemple de génération: openssl rand -hex 32
SESSION_SECRET=your_very_long_random_secret_key_here_min_32_chars

# ========================================
# ENVIRONNEMENT
# ========================================
# Type d'environnement (local, production)
ENVIRONMENT=production

# ========================================
# STOCKAGE FICHIERS (Render Disk)
# ========================================
# Sur Render, les fichiers uploadés doivent être stockés dans un volume persistant
# Créez un "Persistent Disk" dans Render et montez-le sur /opt/render/project/uploads
# Le code utilise automatiquement le dossier ./uploads/
